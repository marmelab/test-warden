{
  "name": "test-warden",
  "version": "0.1.0",
  "description": "MCP server to pilot jest/vitest watch mode over a PTY, so coding agents get warm, fast, on-demand test runs.",
  "type": "module",
  "bin": {
    "test-warden": "src/index.js"
  },
  "files": [
    "src",
    "hooks"
  ],
  "scripts": {
    "start": "node src/index.js",
    "test": "node --test test/"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "node-pty": "^1.0.0",
    "zod": "^3.23.0"
  }
}
